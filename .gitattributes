# Force LF line endings for all text files. Without this, Windows clones
# auto-convert to CRLF, which breaks bash scripts and confuses some parsers.
* text=auto eol=lf

# Explicit LF for shell, Python, JS, JSON, YAML, Markdown, TOML
*.sh   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.toml text eol=lf

# Binary files — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
