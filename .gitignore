# Local sandbox for testing the lib (holoctl init, discovery experiments).
# Anything inside is throwaway — never commit.
dev-sandbox/

# This repo IS the holoctl tool, not a workspace that uses it.
# `.holoctl/` only appears here when someone runs `holoctl init` for
# dogfooding — never commit those artifacts.
.holoctl/

# Generated by `holoctl compile` — source of truth lives in .holoctl/.
# Regenerate locally with `holoctl compile`; never commit the output.
AGENTS.md
CLAUDE.md
